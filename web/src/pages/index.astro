---
/**
 * pages/index.astro — Página de listado del directorio
 * ──────────────────────────────────────────────────────────────────────────────
 * Obtiene todas las personas de WordPress en tiempo de compilación y renderiza
 * una cuadrícula agrupada por departamento con navegación de salto (solo CSS, sin JS).
 *
 * SEO: un solo <h1>, meta descripción, canonical definido vía BaseLayout.
 * Schema: ItemList que envuelve cada ProfilePage — ver página de perfil para el schema Person.
 * ──────────────────────────────────────────────────────────────────────────────
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import PersonCard from '../components/PersonCard.astro';
import { getAllPersonas } from '../lib/wp';
import type { Person } from '../lib/wp';

// getStaticPaths no es necesario en index — se renderiza una sola vez como página estática.
// getAllPersonas() se llama únicamente en tiempo de compilación.
const personas: Person[] = await getAllPersonas();

// Agrupar por departamento para el sidebar de enlaces de salto
const byDepartment = personas.reduce<Record<string, Person[]>>((acc, p) => {
  const dept = p.departamento ?? 'Sin departamento';
  (acc[dept] ??= []).push(p);
  return acc;
}, {});

const departments = Object.keys(byDepartment).sort((a, b) =>
  a.localeCompare(b, 'es'),
);

// Schema.org ItemList
const schemaItemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Directorio de personas — Facultad de Humanidades',
  numberOfItems: personas.length,
  itemListElement: personas.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${Astro.site}personas/${p.slug}`,
    name: p.name,
  })),
};
---

<BaseLayout
  title="Directorio"
  description={`Conoce a los ${personas.length} académicos, investigadores y personal de la Facultad de Humanidades.`}
>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />

  <!-- ── Hero de la página ──────────────────────────────────────────────── -->
  <section class="bg-brand text-white py-14 px-4">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">
        Directorio de personas
      </h1>
      <p class="mt-3 text-brand-accent/90 text-lg max-w-xl">
        Académicos, investigadores y personal administrativo de la Facultad de
        Humanidades.
      </p>
      <!-- Banda de estadísticas rápidas -->
      <dl class="mt-6 flex flex-wrap gap-6 text-sm">
        <div class="flex flex-col">
          <dt class="text-white/60 uppercase tracking-wide text-xs">Personas</dt>
          <dd class="text-2xl font-semibold text-brand-accent">{personas.length}</dd>
        </div>
        <div class="flex flex-col">
          <dt class="text-white/60 uppercase tracking-wide text-xs">Departamentos</dt>
          <dd class="text-2xl font-semibold text-brand-accent">{departments.length}</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ── Contenido principal ────────────────────────────────────────────── -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 flex flex-col lg:flex-row gap-8">
    <!-- Sidebar con enlaces de salto por departamento -->
    <aside
      class="lg:w-56 shrink-0"
      aria-label="Saltar a departamento"
    >
      <nav class="sticky top-4">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">
          Departamentos
        </p>
        <ul class="space-y-1 text-sm" role="list">
          {
            departments.map((dept) => (
              <li>
                <a
                  href={`#dept-${encodeURIComponent(dept)}`}
                  class="flex justify-between items-center text-gray-700 hover:text-brand transition-colors py-1 border-l-2 border-transparent hover:border-brand pl-2"
                >
                  <span class="line-clamp-2">{dept}</span>
                  <span class="text-xs text-gray-400 ml-2 shrink-0">
                    {byDepartment[dept].length}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </aside>

    <!-- Cuadrícula de personas, agrupada por departamento -->
    <div class="flex-1 min-w-0 space-y-12">
      {
        departments.map((dept) => (
          <section aria-labelledby={`dept-heading-${encodeURIComponent(dept)}`}>
            <h2
              id={`dept-heading-${encodeURIComponent(dept)}`}
              class="text-xl font-bold text-gray-900 border-b border-gray-200 pb-2 mb-6"
            >
              <span
                id={`dept-${encodeURIComponent(dept)}`}
                class="scroll-mt-6"
              >
                {dept}
              </span>
            </h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
              {byDepartment[dept].map((persona) => (
                <PersonCard {...persona} />
              ))}
            </div>
          </section>
        ))
      }

      <!-- Estado vacío — solo se renderiza si la API de WP no está configurada aún -->
      {
        personas.length === 0 && (
          <div class="py-24 text-center text-gray-400">
            <p class="text-4xl mb-4" aria-hidden="true">
              📋
            </p>
            <p class="text-lg font-medium text-gray-600">
              No hay personas registradas aún.
            </p>
            <p class="text-sm mt-2">
              Configura <code class="bg-gray-100 px-1 rounded">WP_API_BASE_URL</code>{' '}
              en tu archivo <code class="bg-gray-100 px-1 rounded">.env</code>.
            </p>
          </div>
        )
      }
    </div>
  </div>
</BaseLayout>
