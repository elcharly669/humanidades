---
/**
 * pages/index.astro — Página de listado del directorio
 * ──────────────────────────────────────────────────────────────────────────────
 * Obtiene todas las personas de WordPress en tiempo de compilación y renderiza
 * una cuadrícula agrupada por departamento con navegación de salto (solo CSS, sin JS).
 *
 * SEO: un solo <h1>, meta descripción, canonical definido vía BaseLayout.
 * Schema: ItemList que envuelve cada ProfilePage — ver página de perfil para el schema Person.
 * ──────────────────────────────────────────────────────────────────────────────
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import PersonCard from '../components/PersonCard.astro';
import { getAllPersonas } from '../lib/wp';
import type { Person } from '../lib/wp';

// getStaticPaths no es necesario en index — se renderiza una sola vez como página estática.
// getAllPersonas() se llama únicamente en tiempo de compilación.
const personas: Person[] = await getAllPersonas();

// Agrupar por departamento para el sidebar de enlaces de salto
const byDepartment = personas.reduce<Record<string, Person[]>>((acc, p) => {
  const dept = p.departamento ?? 'Sin departamento';
  (acc[dept] ??= []).push(p);
  return acc;
}, {});

const departments = Object.keys(byDepartment).sort((a, b) =>
  a.localeCompare(b, 'es'),
);

// Schema.org ItemList
const schemaItemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Directorio de personas — Facultad de Humanidades',
  numberOfItems: personas.length,
  itemListElement: personas.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${Astro.site}personas/${p.slug}`,
    name: p.name,
  })),
};
---

<BaseLayout
  title="Directorio"
  description={`Conoce a los ${personas.length} académicos, investigadores y personal de la Facultad de Humanidades.`}
>
  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />

  <!-- ── Encabezado editorial ───────────────────────────────────────────── -->
  <div class="max-w-layout mx-auto px-6 sm:px-8 pt-14 pb-8 border-b border-paper-border">
    <p class="text-xs tracking-[0.2em] uppercase text-ink-muted mb-5">
      Directorio académico &middot; {personas.length} personas &middot; {departments.length} departamentos
    </p>
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-ink leading-tight">
      Directorio de personas
    </h1>
  </div>

  <!-- ── Contenido principal ─────────────────────────────────────────────── -->
  <div class="max-w-layout mx-auto px-6 sm:px-8 py-10 flex flex-col lg:flex-row gap-12">
    <!-- Sidebar — filtro por departamento (JS puro, cero dependencias) -->
    <aside class="lg:w-52 shrink-0" aria-label="Filtrar por departamento">
      <nav class="sticky top-6">
        <p class="text-xs tracking-[0.2em] uppercase text-ink-muted mb-4">Departamentos</p>
        <ul class="space-y-0.5" role="list">
          <!-- Botón “Todos” -->
          <li>
            <button
              id="filter-all"
              data-filter=""
              class="filter-btn w-full flex justify-between items-center text-sm py-2 border-l-2 border-brand-accent pl-3 text-ink font-medium transition-all text-left"
              aria-pressed="true"
            >
              <span>Todos</span>
              <span class="text-xs text-ink-muted ml-3 tabular-nums">{personas.length}</span>
            </button>
          </li>
          {
            departments.map((dept) => (
              <li>
                <button
                  data-filter={dept}
                  class="filter-btn w-full flex justify-between items-center text-sm py-2 border-l-2 border-transparent pl-3 text-ink-soft hover:text-ink hover:border-brand-accent transition-all text-left focus-visible:outline-2 focus-visible:outline-brand rounded-sm"
                  aria-pressed="false"
                >
                  <span class="line-clamp-2 leading-snug">{dept}</span>
                  <span class="text-xs text-ink-muted ml-3 shrink-0 tabular-nums">
                    {byDepartment[dept].length}
                  </span>
                </button>
              </li>
            ))
          }
        </ul>
      </nav>
    </aside>

      <!-- Lista de personas agrupada por departamento -->
      <div class="flex-1 min-w-0 space-y-14" id="directory-list">
        {
          departments.map((dept) => (
            <section
              aria-labelledby={`dept-heading-${encodeURIComponent(dept)}`}
              data-dept={dept}
            >
              <h2
                id={`dept-heading-${encodeURIComponent(dept)}`}
                class="text-xs tracking-[0.2em] uppercase text-ink-muted mb-3"
              >
                <span id={`dept-${encodeURIComponent(dept)}`} class="scroll-mt-20">{dept}</span>
              </h2>
              <div class="border-t border-paper-border">
                {byDepartment[dept].map((persona) => (
                  <PersonCard {...persona} />
                ))}
              </div>
            </section>
          ))
        }

      <!-- Estado vacío — solo si WP no está configurado -->
      {
        personas.length === 0 && (
          <div class="py-24 text-center text-ink-faint">
            <p class="text-4xl mb-4" aria-hidden="true">📋</p>
            <p class="text-lg font-medium text-ink-muted">No hay personas registradas aún.</p>
            <p class="text-sm mt-2">
              Configura <code class="bg-paper-warm text-ink-soft px-1 rounded">WP_API_BASE_URL</code>{' '}
              en tu archivo <code class="bg-paper-warm text-ink-soft px-1 rounded">.env</code>.
            </p>
          </div>
        )
      }
    </div>
  </div>
</BaseLayout>
