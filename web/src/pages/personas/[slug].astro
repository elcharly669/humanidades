---
/**
 * pages/personas/[slug].astro — Página de perfil individual
 * ──────────────────────────────────────────────────────────────────────────────
 * Generación estática: getStaticPaths() obtiene TODAS las personas en tiempo de
 * compilación y devuelve una ruta por slug. Sin solicitudes a WP en tiempo de ejecución.
 *
 * SEO / Schema.org:
 *   - <title> = nombre completo de la persona
 *   - JSON-LD Schema.org Person inyectado en <head> vía BaseLayout
 *   - URL canónica definida explícitamente para evitar duplicados por slug/ID
 *
 * Accesibilidad:
 *   - Un solo <h1> (nombre de la persona)
 *   - Lista de publicaciones usa <ol> (ordenada, implica orden de relevancia)
 *   - El aria-label del enlace de correo incluye el nombre para identificar el destino
 * ──────────────────────────────────────────────────────────────────────────────
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPersonas } from '../../lib/wp';
import type { Person } from '../../lib/wp';

export async function getStaticPaths() {
  const personas = await getAllPersonas();
  return personas.map((persona) => ({
    params: { slug: persona.slug },
    props: { persona },
  }));
}

interface Props {
  persona: Person;
}

const { persona } = Astro.props;
const {
  name,
  slug,
  titulo,
  departamento,
  areasInvestigacion,
  email,
  bio,
  photoUrl,
  publicaciones,
} = persona;

// URL canónica — siempre en forma /personas/[slug], nunca en variante ?id=
const canonicalURL = new URL(`/personas/${slug}`, Astro.site).href;

// ── Schema.org Person ─────────────────────────────────────────────────────────
const schemaPerson: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name,
  url: canonicalURL,
};
if (titulo) schemaPerson.jobTitle = titulo;
if (departamento)
  schemaPerson.worksFor = {
    '@type': 'Organization',
    name: 'Facultad de Humanidades',
    department: departamento,
  };
if (email) schemaPerson.email = `mailto:${email}`;
if (photoUrl) schemaPerson.image = photoUrl;
if (areasInvestigacion.length > 0)
  schemaPerson.knowsAbout = areasInvestigacion;
if (publicaciones.length > 0)
  schemaPerson.author = publicaciones.map((p) => ({
    '@type': 'ScholarlyArticle',
    name: p.titulo,
    author: p.autores,
    datePublished: p.anio?.toString(),
    url: p.url,
  }));

// Descripción para meta tag
const metaDescription = bio
  ? bio.replace(/<[^>]*>/g, '').slice(0, 157) + '…'
  : `Perfil académico de ${name}${titulo ? `, ${titulo}` : ''}${departamento ? ` — ${departamento}` : ''}.`;

// Iniciales de respaldo
const initials = name
  .split(' ')
  .filter(Boolean)
  .slice(0, 2)
  .map((w) => w[0].toUpperCase())
  .join('');
---

<BaseLayout
  title={name}
  description={metaDescription}
  ogImage={photoUrl}
  canonicalURL={canonicalURL}
>
  <!-- Schema.org JSON-LD -->
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(schemaPerson)}
  />

  <!-- ── Hero del perfil — alineado con paleta paper/ink ─────────────────── -->
  <section class="border-b border-paper-border">
    <div
      class="max-w-layout mx-auto px-6 sm:px-8 pt-12 pb-10 flex flex-col sm:flex-row items-start sm:items-end gap-8"
    >
      <!-- Avatar grande -->
      <div
        class="w-24 h-24 sm:w-32 sm:h-32 rounded-full overflow-hidden ring-2 ring-paper-border shrink-0"
        aria-hidden="true"
      >
        {
          photoUrl ? (
            <img
              src={photoUrl}
              alt={`Fotografía de ${name}`}
              class="w-full h-full object-cover"
              loading="eager"
              decoding="async"
              width="128"
              height="128"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center bg-brand/10 text-brand text-3xl font-medium">
              {initials}
            </div>
          )
        }
      </div>

      <!-- Nombre + metadatos — jerarquía editorial -->
      <div class="flex-1 min-w-0">
        <!-- Breadcrumb de contexto -->
        <p class="text-xs tracking-[0.18em] uppercase text-ink-muted mb-3">
          <a href="/" class="hover:text-ink transition-colors">Directorio</a>
          {departamento && (
            <> &middot; {departamento}</>
          )}
        </p>

        <!-- Nombre — h1 principal -->
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-ink tracking-tight leading-tight">
          {name}
        </h1>

        <!-- Cargo/título académico — subtítulo prominente -->
        {titulo && (
          <p class="mt-2 text-lg sm:text-xl text-brand font-medium leading-snug">
            {titulo}
          </p>
        )}

        <!-- Acciones: email CTA + volver -->
        <div class="mt-5 flex flex-wrap gap-3 items-center">
          {email && (
            <a
              href={`mailto:${email}`}
              class="inline-flex items-center gap-2 px-4 py-2 bg-brand text-paper/90 text-sm font-medium rounded-full hover:bg-brand-light transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-accent"
              aria-label={`Enviar correo electrónico a ${name}`}
            >
              <!-- Icono envelope -->
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
              </svg>
              Enviar mensaje
            </a>
          )}
          {email && (
            <span class="text-xs text-ink-muted hidden sm:inline">{email}</span>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Contenido principal del perfil ──────────────────────────────────── -->
  <div
    class="max-w-layout mx-auto px-6 sm:px-8 py-12 grid grid-cols-1 lg:grid-cols-3 gap-12"
  >
    <!-- ── Izquierda: bio + publicaciones ──────────────────────────────────── -->
    <div class="lg:col-span-2 space-y-12">
      <!-- Biografía -->
      {
        bio && (
          <section aria-labelledby="bio-heading">
            <h2
              id="bio-heading"
              class="text-xs tracking-[0.18em] uppercase text-ink-muted mb-4 pb-2 border-b border-paper-border"
            >
              Semblanza
            </h2>
            <!-- El bio es HTML de WP; sanitizado en la capa de WP -->
            <div
              class="prose prose-lg max-w-none text-ink-soft leading-relaxed
                     prose-headings:text-ink prose-headings:font-semibold
                     prose-a:text-brand prose-a:no-underline hover:prose-a:underline
                     prose-strong:text-ink-soft"
              set:html={bio}
            />
          </section>
        )
      }

      <!-- Publicaciones -->
      {
        publicaciones.length > 0 && (
          <section aria-labelledby="pub-heading">
            <h2
              id="pub-heading"
              class="text-xs tracking-[0.18em] uppercase text-ink-muted mb-4 pb-2 border-b border-paper-border"
            >
              Publicaciones seleccionadas
            </h2>
            <ol class="space-y-5" role="list">
              {publicaciones.map((pub) => (
                <li class="flex gap-4">
                  <!-- Marcador decorativo -->
                  <span
                    class="text-brand-accent font-semibold text-base shrink-0 mt-0.5 select-none"
                    aria-hidden="true"
                  >
                    ▸
                  </span>
                  <div>
                    {pub.url ? (
                      <a
                        href={pub.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-base font-medium text-brand hover:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand rounded-sm"
                      >
                        {pub.titulo}
                      </a>
                    ) : (
                      <p class="text-base font-medium text-ink">{pub.titulo}</p>
                    )}
                    <p class="text-sm text-ink-muted mt-0.5">
                      {[pub.autores, pub.anio].filter(Boolean).join(' · ')}
                    </p>
                  </div>
                </li>
              ))}
            </ol>
          </section>
        )
      }
    </div>

    <!-- ── Derecha: sidebar de áreas + navegación ───────────────────────── -->
    <aside aria-label="Información complementaria" class="space-y-8">
      <div class="sticky top-6 space-y-8">
        <!-- Áreas de investigación -->
        {
          areasInvestigacion.length > 0 && (
            <section aria-labelledby="areas-heading">
              <h2
                id="areas-heading"
                class="text-xs tracking-[0.18em] uppercase text-ink-muted mb-4 pb-2 border-b border-paper-border"
              >
                Áreas de investigación
              </h2>
              <ul class="flex flex-wrap gap-2" role="list">
                {areasInvestigacion.map((area) => (
                  <li class="text-sm text-ink-muted border border-paper-border px-3 py-1 rounded-full leading-6">
                    {area}
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        <!-- Enlace de regreso al directorio -->
        <div class="border-t border-paper-border pt-6">
          <a
            href="/"
            class="inline-flex items-center gap-2 text-sm text-ink-muted hover:text-ink transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand rounded-sm"
            aria-label="Volver al directorio completo"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z"
                clip-rule="evenodd"
              />
            </svg>
            Volver al directorio
          </a>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>
