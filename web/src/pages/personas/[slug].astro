---
/**
 * pages/personas/[slug].astro — Página de perfil individual
 * ──────────────────────────────────────────────────────────────────────────────
 * Generación estática: getStaticPaths() obtiene TODAS las personas en tiempo de
 * compilación y devuelve una ruta por slug. Sin solicitudes a WP en tiempo de ejecución.
 *
 * SEO / Schema.org:
 *   - <title> = nombre completo de la persona
 *   - JSON-LD Schema.org Person inyectado en <head> vía BaseLayout
 *   - URL canónica definida explícitamente para evitar duplicados por slug/ID
 *
 * Accesibilidad:
 *   - Un solo <h1> (nombre de la persona)
 *   - Lista de publicaciones usa <ol> (ordenada, implica orden de relevancia)
 *   - El aria-label del enlace de correo incluye el nombre para identificar el destino
 * ──────────────────────────────────────────────────────────────────────────────
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPersonas } from '../../lib/wp';
import type { Person } from '../../lib/wp';

export async function getStaticPaths() {
  const personas = await getAllPersonas();
  return personas.map((persona) => ({
    params: { slug: persona.slug },
    props: { persona },
  }));
}

interface Props {
  persona: Person;
}

const { persona } = Astro.props;
const {
  name,
  slug,
  titulo,
  departamento,
  areasInvestigacion,
  email,
  bio,
  photoUrl,
  publicaciones,
} = persona;

// URL canónica — siempre en forma /personas/[slug], nunca en variante ?id=
const canonicalURL = new URL(`/personas/${slug}`, Astro.site).href;

// ── Schema.org Person ─────────────────────────────────────────────────────────
// Especificación completa: https://schema.org/Person
// Los campos se omiten intencionalmente cuando están vacíos para mantener el JSON-LD limpio.
const schemaPerson: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name,
  url: canonicalURL,
};
if (titulo) schemaPerson.jobTitle = titulo;
if (departamento)
  schemaPerson.worksFor = {
    '@type': 'Organization',
    name: 'Facultad de Humanidades',
    department: departamento,
  };
if (email) schemaPerson.email = `mailto:${email}`;
if (photoUrl) schemaPerson.image = photoUrl;
if (areasInvestigacion.length > 0)
  schemaPerson.knowsAbout = areasInvestigacion;
if (publicaciones.length > 0)
  schemaPerson.author = publicaciones.map((p) => ({
    '@type': 'ScholarlyArticle',
    name: p.titulo,
    author: p.autores,
    datePublished: p.anio?.toString(),
    url: p.url,
  }));

// Descripción para meta tag: prefiere los primeros 160 caracteres del bio, si no usa texto genérico
const metaDescription = bio
  ? bio.replace(/<[^>]*>/g, '').slice(0, 157) + '…'
  : `Perfil académico de ${name}${titulo ? `, ${titulo}` : ''}${departamento ? ` — ${departamento}` : ''}.`;

// Iniciales de respaldo
const initials = name
  .split(' ')
  .filter(Boolean)
  .slice(0, 2)
  .map((w) => w[0].toUpperCase())
  .join('');
---

<BaseLayout
  title={name}
  description={metaDescription}
  ogImage={photoUrl}
  canonicalURL={canonicalURL}
>
  <!-- Schema.org JSON-LD en <head> vía mecanismo de slot de BaseLayout -->
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(schemaPerson)}
  />

  <!-- ── Hero del perfil ───────────────────────────────────────────────── -->
  <section class="bg-brand text-white">
    <div
      class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex flex-col sm:flex-row items-center sm:items-end gap-8"
    >
      <!-- Avatar -->
      <div
        class="w-36 h-36 sm:w-44 sm:h-44 rounded-full overflow-hidden border-4 border-brand-accent shadow-xl shrink-0"
        aria-hidden="true"
      >
        {
          photoUrl ? (
            <img
              src={photoUrl}
              alt={`Fotografía de ${name}`}
              class="w-full h-full object-cover"
              loading="eager"
              decoding="async"
              width="176"
              height="176"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center bg-brand-light text-white text-5xl font-semibold">
              {initials}
            </div>
          )
        }
      </div>

      <!-- Nombre + metadatos -->
      <div class="text-center sm:text-left">
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">{name}</h1>
        {
          titulo && (
            <p class="mt-1 text-brand-accent text-lg font-medium">{titulo}</p>
          )
        }
        {
          departamento && (
            <p class="mt-0.5 text-white/70 text-sm">{departamento}</p>
          )
        }
        {
          email && (
            <a
              href={`mailto:${email}`}
              class="inline-block mt-3 text-sm text-brand-accent hover:underline"
              aria-label={`Enviar correo electrónico a ${name}`}
            >
              {email}
            </a>
          )
        }
      </div>
    </div>
  </section>

  <!-- ── Contenido principal del perfil ───────────────────────────────── -->
  <div
    class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 grid grid-cols-1 lg:grid-cols-3 gap-10"
  >
    <!-- ── Izquierda: bio + publicaciones ──────────────────────────────── -->
    <div class="lg:col-span-2 space-y-10">
      <!-- Biografía -->
      {
        bio && (
          <section aria-labelledby="bio-heading">
            <h2
              id="bio-heading"
              class="text-lg font-semibold text-gray-900 mb-3 border-b border-gray-200 pb-2"
            >
              Semblanza
            </h2>
            <!-- El bio es HTML de WP; sanitizado en la capa de WP (sin HTML de usuario directo) -->
            <div
              class="prose prose-sm prose-gray max-w-none text-gray-700 leading-relaxed"
              set:html={bio}
            />
          </section>
        )
      }

      <!-- Publicaciones -->
      {
        publicaciones.length > 0 && (
          <section aria-labelledby="pub-heading">
            <h2
              id="pub-heading"
              class="text-lg font-semibold text-gray-900 mb-3 border-b border-gray-200 pb-2"
            >
              Publicaciones seleccionadas
            </h2>
            <ol class="space-y-4" role="list">
              {publicaciones.map((pub) => (
                <li class="flex gap-3">
                  <span
                    class="text-brand-accent font-semibold text-sm shrink-0 mt-0.5"
                    aria-hidden="true"
                  >
                    ▸
                  </span>
                  <div>
                    {pub.url ? (
                      <a
                        href={pub.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm font-medium text-brand hover:underline"
                      >
                        {pub.titulo}
                      </a>
                    ) : (
                      <p class="text-sm font-medium text-gray-900">{pub.titulo}</p>
                    )}
                    <p class="text-xs text-gray-500 mt-0.5">
                      {[pub.autores, pub.anio].filter(Boolean).join(' · ')}
                    </p>
                  </div>
                </li>
              ))}
            </ol>
          </section>
        )
      }
    </div>

    <!-- ── Derecha: sidebar de áreas ─────────────────────────────────────── -->
    <aside aria-label="Áreas de investigación">
      <div class="bg-gray-50 rounded-xl p-5 sticky top-4 space-y-6">
        {
          areasInvestigacion.length > 0 && (
            <section aria-labelledby="areas-heading">
              <h2
                id="areas-heading"
                class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3"
              >
                Áreas de investigación
              </h2>
              <ul class="flex flex-wrap gap-2" role="list">
                {areasInvestigacion.map((area) => (
                  <li class="text-xs bg-brand/10 text-brand-light px-2.5 py-1 rounded-full font-medium">
                    {area}
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        <!-- Enlace de regreso -->
        <a
          href="/"
          class="flex items-center gap-1.5 text-sm text-gray-600 hover:text-brand transition-colors mt-4"
          aria-label="Volver al directorio completo"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z"
              clip-rule="evenodd"
            />
          </svg>
          Volver al directorio
        </a>
      </div>
    </aside>
  </div>
</BaseLayout>
