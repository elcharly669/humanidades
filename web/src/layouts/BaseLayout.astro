---
// Fuentes autoalojadas vía @fontsource — sin peticiones a Google Fonts
import '@fontsource/eb-garamond/400.css';
import '@fontsource/eb-garamond/400-italic.css';
import '@fontsource/eb-garamond/500.css';
/**
 * BaseLayout.astro
 * ──────────────────────────────────────────────────────────────────────────────
 * Estructura compartida para todas las páginas. Se encarga de:
 *   - <head> con canonical, OG y meta de Twitter
 *   - Enlace de saltar navegación (WCAG 2.4.1)
 *   - Navegación del sitio con estructura amigable para móviles
 *   - Pie de página con crédito institucional
 *
 * Props:
 *   title        — <title> de la página (requerido)
 *   description  — Meta descripción (requerido, máximo 160 caracteres)
 *   ogImage      — URL absoluta para imagen OG (opcional, usa imagen por defecto)
 *   canonicalURL — Sobreescribe la URL canónica (opcional, por defecto usa Astro.url)
 * ──────────────────────────────────────────────────────────────────────────────
 */

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  canonicalURL = Astro.url.href,
} = Astro.props;

// Nombre del sitio inyectado en tiempo de compilación; se usa en el sufijo de <title> y etiquetas OG
const SITE_NAME = 'Directorio · Facultad de Humanidades';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Meta primarios -->
    <title>{title} | {SITE_NAME}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | ${SITE_NAME}`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:locale" content="es_MX" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | ${SITE_NAME}`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fuente EB Garamond incluida en el bundle vía @fontsource (sin peticiones externas) -->

    <!-- Pista de encabezado de seguridad: el CSP se aplica principalmente en Cloudflare / servidor.
         Esta etiqueta meta provee una capa adicional de protección. -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; img-src 'self' data: https:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' https://www.googletagmanager.com"
    />

    <!-- Google Tag Manager — carga de forma asíncrona, no bloquea el renderizado -->
    <!-- Reemplaza GTM-XXXXXXX con el ID real del contenedor antes del lanzamiento -->
    <!-- prettier-ignore -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-XXXXXXX');</script>
  </head>

  <body class="bg-paper text-ink font-sans antialiased">
    <!-- Fallback noscript de GTM — necesario para que los tags funcionen sin JS -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-XXXXXXX"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe>
    </noscript>

    <!-- Enlace de saltar navegación — visible al recibir foco de teclado -->
    <a
      href="#main-content"
      class="sr-only focus-visible:not-sr-only focus-visible:fixed focus-visible:top-4 focus-visible:left-4 focus-visible:z-50 focus-visible:px-4 focus-visible:py-2 focus-visible:bg-brand focus-visible:text-paper focus-visible:rounded focus-visible:text-sm focus-visible:font-semibold focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-accent"
    >
      Saltar al contenido principal
    </a>

    <!-- ── Navegación minimalista ───────────────────────────────────────── -->
    <header class="border-b border-paper-border">
      <nav
        class="max-w-layout mx-auto px-6 sm:px-8 h-14 flex items-center justify-between"
        aria-label="Navegación principal"
      >
        <!-- Logotipo — reemplazar ⬡ con <img> del escudo real -->
        <a
          href="/"
          class="flex items-center gap-2 text-xs tracking-[0.16em] uppercase text-ink font-medium hover:text-brand transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand rounded-sm"
        >
          <span aria-hidden="true" class="text-brand-accent text-base">⬡</span>
          Humanidades
        </a>

        <!-- Links escritorio en versalitas — mínimo text-xs para WCAG 1.4.4 -->
        <ul class="hidden sm:flex items-center gap-8 text-xs tracking-[0.14em] uppercase text-ink-muted" role="list">
          <li><a href="/" class="hover:text-ink transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand rounded-sm py-1 px-0.5">Directorio</a></li>
          <li><a href="/departamentos" class="hover:text-ink transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand rounded-sm py-1 px-0.5">Departamentos</a></li>
          <li><a href="/investigacion" class="hover:text-ink transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand rounded-sm py-1 px-0.5">Investigación</a></li>
        </ul>

        <!-- Toggle móvil -->
        <label
          for="mobile-menu-toggle"
          class="sm:hidden cursor-pointer p-2 rounded hover:bg-paper-warm transition-colors text-ink-muted"
          aria-label="Abrir menú"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </label>
      </nav>

      <!-- Menú móvil -->
      <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
      <div class="hidden peer-checked:block sm:hidden border-t border-paper-border">
        <ul class="max-w-layout mx-auto px-6 py-3 space-y-1 text-xs tracking-[0.14em] uppercase text-ink-muted" role="list">
          <li><a href="/" class="block py-2.5 hover:text-ink transition-colors focus-visible:outline-2 focus-visible:outline-brand rounded-sm">Directorio</a></li>
          <li><a href="/departamentos" class="block py-2.5 hover:text-ink transition-colors focus-visible:outline-2 focus-visible:outline-brand rounded-sm">Departamentos</a></li>
          <li><a href="/investigacion" class="block py-2.5 hover:text-ink transition-colors focus-visible:outline-2 focus-visible:outline-brand rounded-sm">Investigación</a></li>
        </ul>
      </div>
    </header>

    <!-- ── Slot de contenido de la página ───────────────────────────────── -->
    <!-- outline-none: evita el contorno del navegador al focus programático del skip link -->
    <main id="main-content" tabindex="-1" class="outline-none">
      <slot />
    </main>

    <!-- ── Pie minimalista ──────────────────────────────────────────────── -->
    <footer class="border-t border-paper-border mt-20">
      <div
        class="max-w-layout mx-auto px-6 sm:px-8 py-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4"
      >
        <p class="text-xs text-ink-faint tracking-wide">
          Facultad de Humanidades &middot; Universidad &middot; Ciudad, País
        </p>
        <ul class="flex flex-wrap gap-6 text-xs text-ink-faint" role="list">
          <li><a href="/aviso-privacidad" class="hover:text-ink-muted transition-colors">Aviso de privacidad</a></li>
          <li><a href="/contacto" class="hover:text-ink-muted transition-colors">Contacto</a></li>
          <li>
            <a href="https://github.com/your-org/humanities-web" target="_blank" rel="noopener noreferrer" class="hover:text-ink-muted transition-colors">
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </footer>
  </body>
</html>
