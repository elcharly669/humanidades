---
/**
 * PersonCard.astro
 * ──────────────────────────────────────────────────────────────────────────────
 * Fila editorial del directorio — toda la fila es clickeable (overlay link).
 * Jerarquía: Nombre → Cargo → Email CTA → Áreas | Departamento (derecha)
 * ──────────────────────────────────────────────────────────────────────────────
 */

interface Props {
  slug: string;
  prefix?: string;
  name: string;
  titulo?: string;
  departamento?: string;
  areasInvestigacion: string[];
  photoUrl?: string;
  email?: string;
}

const { slug, prefix, name, titulo, departamento, areasInvestigacion, photoUrl, email } =
  Astro.props;

// Iniciales de respaldo cuando no hay foto disponible (usa solo el nombre, sin prefijo)
const initials = name
  .split(' ')
  .filter(Boolean)
  .slice(0, 2)
  .map((w) => w[0].toUpperCase())
  .join('');
---

<article
  class="group relative flex items-start gap-4 sm:gap-6 py-5 sm:py-7 border-b border-paper-border hover:bg-paper-warm transition-colors duration-150"
  aria-labelledby={`person-name-${slug}`}
>
  <!-- Overlay: hace toda la fila clickeable sin anidar <a> en <a> -->
  <a
    href={`/personas/${slug}`}
    class="absolute inset-0 z-0 rounded-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
    aria-hidden="true"
    tabindex="-1"
  ></a>

  <!-- Avatar -->
  <div class="relative z-10 shrink-0 mt-0.5" aria-hidden="true">
    <div class="w-11 h-11 sm:w-12 sm:h-12 rounded-full overflow-hidden ring-1 ring-paper-border">
      {
        photoUrl ? (
          <img
            src={photoUrl}
            alt={`Fotografía de ${name}`}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            loading="lazy"
            decoding="async"
            width="48"
            height="48"
          />
        ) : (
          <div
            class="w-full h-full flex items-center justify-center bg-brand/10 text-brand font-medium text-sm"
            aria-hidden="true"
          >
            {initials}
          </div>
        )
      }
    </div>
  </div>

  <!-- Columna principal: nombre, cargo, CTA de email, áreas -->
  <div class="relative z-10 flex-1 min-w-0">
    <!-- Nombre — CTA primario -->
    <h2
      id={`person-name-${slug}`}
      class="text-base sm:text-lg font-medium text-ink leading-snug"
    >
      {prefix && (
        <!-- Tratamiento académico: ligeramente más pequeño y atenuado -->
        <span class="text-sm sm:text-base font-normal text-ink-muted mr-1">{prefix}</span>
      )}
      <a
        href={`/personas/${slug}`}
        class="relative z-10 hover:text-brand transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand rounded-sm"
      >
        {name}
      </a>
    </h2>

    <!-- Cargo — subtítulo visible y legible -->
    {titulo && (
      <p class="text-sm sm:text-base text-ink-soft mt-0.5 leading-snug">{titulo}</p>
    )}

    <!-- Email como CTA secundario — solo en móvil (escritorio va en columna derecha) -->
    {email && (
      <a
        href={`mailto:${email}`}
        class="relative z-10 inline-flex items-center gap-1 mt-2 text-xs text-brand border border-brand/25 bg-brand/5 hover:bg-brand/10 px-2.5 py-1 rounded-full transition-colors md:hidden focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
        aria-label={`Enviar correo a ${name}`}
      >
        <!-- Icono envelope -->
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
          <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
        </svg>
        {email}
      </a>
    )}

    <!-- Áreas de investigación -->
    {
      areasInvestigacion.length > 0 && (
        <ul
          class="flex flex-wrap gap-1.5 mt-2.5"
          aria-label="Áreas de investigación"
          role="list"
        >
          {areasInvestigacion.slice(0, 3).map((area) => (
            <li class="relative z-10 text-xs tracking-wide uppercase text-ink-muted border border-paper-border px-2 py-0.5 rounded-sm leading-5">
              {area}
            </li>
          ))}
          {areasInvestigacion.length > 3 && (
            <li
              class="text-xs text-ink-muted self-center"
              aria-label={`y ${areasInvestigacion.length - 3} áreas más`}
            >
              +{areasInvestigacion.length - 3}
            </li>
          )}
        </ul>
      )
    }
  </div>

  <!-- Columna derecha — solo escritorio: departamento + email CTA -->
  <div class="relative z-10 hidden md:flex flex-col items-end gap-2 shrink-0 max-w-[240px] pt-0.5">
    {departamento && (
      <!-- Pill neutro: mismo border-radius que el CTA de email para equilibrio visual -->
      <span class="inline-flex items-center text-xs text-ink-muted border border-paper-border px-3 py-1.5 rounded-full leading-none">
        {departamento}
      </span>
    )}
    {email && (
      <a
        href={`mailto:${email}`}
        class="inline-flex items-center gap-1.5 text-xs text-brand border border-brand/25 bg-brand/5 hover:bg-brand/10 px-3 py-1.5 rounded-full transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
        aria-label={`Enviar correo a ${name}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
          <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
        </svg>
        Escribir
      </a>
    )}
  </div>
</article>
