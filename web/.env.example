# WP_API_BASE_URL es la URL completa de tu instalación de WordPress, sin barra final.
# Este valor se usa ÚNICAMENTE en tiempo de compilación (build estático de Astro).
# Los usuarios finales nunca contactan WordPress directamente.
WP_API_BASE_URL=https://cms.humanidades.example.edu

# URL completa donde se desplegará el sitio Astro.
# Se usa para URLs canónicas y etiquetas OG.
SITE_URL=https://humanidades.example.edu
